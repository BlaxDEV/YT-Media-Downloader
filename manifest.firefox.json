{
  "name": "YT Media Downloader",
  "version": "1.1.7",
  "version_name": "v.1.1.7-release",
  "description": "Download YouTube videos and audio locally in high definition without ads",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-downloader@blaxvt",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "isExempt": true,
        "required": ["none"],
        "description": "This extension communicates strictly with a local companion server (127.0.0.1:19836) to process downloads. It does not collect or transmit any user data to third parties."
      }
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:19836/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["i18n.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
