{
  "name": "YT Media Downloader",
  "version": "1.2.1",
  "version_name": "v.1.2.1-release",
  "description": "Download YouTube videos and audio locally in high definition without ads",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-downloader@blaxvt",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "isExempt": true,
        "required": ["none"],
        "description": "This extension communicates strictly with a local companion server (127.0.0.1:19836) to process downloads. It does not collect or transmit any user data to third parties."
      }
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:19836/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": [
        "i18n.js",
        "content/core.js",
        "content/icons.js",
        "content/buttons.js",
        "content/panel.js",
        "content/panel-i18n.js",
        "content/sliders.js",
        "content/preview.js",
        "content/history.js",
        "content/video-data.js",
        "content/download.js",
        "content/panel-events.js",
        "content/observer.js",
        "content/content.js"
      ],
      "css": [
        "content/css/action-btn.css",
        "content/css/base.css",
        "content/css/controls.css",
        "content/css/trim.css",
        "content/css/download.css",
        "content/css/preview.css",
        "content/css/extras.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
